# husn.io — local dev environment

# Postgres
POSTGRES_USER=husn
POSTGRES_PASSWORD=husn
POSTGRES_DB=husn
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Async SQLAlchemy DSN (used by api + workers inside docker)
DATABASE_URL=postgresql+asyncpg://husn:husn@postgres:5432/husn

# Redis (Arq queue + cache)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# API
HUSN_API_HOST=0.0.0.0
HUSN_API_PORT=8000
HUSN_ENV=local
HUSN_LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Connector credentials (filled in later steps; empty for the MVP skeleton)
SLACK_CLIENT_ID=
SLACK_CLIENT_SIGNING_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
