# husn.io — local dev environment

# Postgres
POSTGRES_USER=husn
POSTGRES_PASSWORD=husn
POSTGRES_DB=husn
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Async SQLAlchemy DSN (used by api + workers inside docker)
DATABASE_URL=postgresql+asyncpg://husn:husn@postgres:5432/husn

# Redis (Arq queue + cache)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# API
HUSN_API_HOST=0.0.0.0
HUSN_API_PORT=8000
HUSN_ENV=local
HUSN_LOG_LEVEL=info

# Frontend
# API_URL — used by Next.js SERVER-SIDE code (inside the web container).
#   In docker, services reach each other by service name, so use http://api:8000.
# NEXT_PUBLIC_API_URL — used by BROWSER code.
#   The browser runs on the host, so it must use the host-exposed port.
API_URL=http://api:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Connector credentials (filled in later steps; empty for the MVP skeleton)
SLACK_CLIENT_ID=
SLACK_CLIENT_SIGNING_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Step 6 LLM agent backend (ollama | groq | anthropic | claude_cli)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
