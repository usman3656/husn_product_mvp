# .env.prod.example
# Copy to .env.prod on the production host and fill in. NEVER commit .env.prod.
# Used by docker-compose.prod.yml (caddy + service env_file) and the FastAPI app.

# ---------- Caddy / DNS ----------
DOMAIN_APP=app.husn.io
DOMAIN_API=api.husn.io
DOMAIN_ROOT=husn.io
ACME_EMAIL=ops@husn.io

# ---------- Runtime / logging ----------
ENVIRONMENT=production
LOG_LEVEL=info
LOG_FORMAT=json

# ---------- Postgres ----------
POSTGRES_USER=husn
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
POSTGRES_DB=husn

# ---------- Session / crypto ----------
SESSION_SECRET=CHANGE_ME_LONG_RANDOM
TOKEN_ENCRYPTION_KEY=CHANGE_ME_BASE64_32B

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=https://app.husn.io

# ---------- Public origins (mirror NEXT_PUBLIC_API_URL set in compose) ----------
PUBLIC_API_BASE_URL=https://api.husn.io
PUBLIC_WEB_BASE_URL=https://app.husn.io

# ---------- Atlassian / Jira OAuth ----------
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# ---------- Slack OAuth ----------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Microsoft / Entra OAuth ----------
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=common

# ---------- LLM providers ----------
LLM_PROVIDER=groq
LLM_REQUEST_TIMEOUT_S=180

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (fallback if Groq reject rates are bad in Step 5 v2)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
