# .env.staging.example — STAGING environment config.
#
# Set up on the box at ~/husn-staging/.env.staging :
#   1. cp .env.prod  ~/husn-staging/.env.staging     # start from prod
#   2. OVERRIDE the values below (these MUST differ from prod for isolation)
#   3. chmod 600 .env.staging
#
# Anything not listed here can stay the same as prod. The ones below are the
# ones that MUST be staging-specific so staging never collides with prod.

# --- Domains (drive Caddy routing, web build, and OAuth redirect URIs) ---
DOMAIN_APP=staging.husn.io
DOMAIN_API=api-staging.husn.io
PUBLIC_WEB_BASE_URL=https://staging.husn.io
PUBLIC_API_BASE_URL=https://api-staging.husn.io

# --- Cookies: leave host-only so a staging session can't be sent to prod
#     (and vice-versa). Do NOT set this to .husn.io. ---
COOKIE_DOMAIN=

# --- Database: a distinct name (the volume is already separate via the
#     husn-staging project, but a distinct name avoids any confusion). A
#     separate password is good hygiene. ---
POSTGRES_DB=husn_staging
POSTGRES_USER=husn
POSTGRES_PASSWORD=CHANGE_ME_staging_db_password

# --- Secrets that MUST be separate from prod ---
# New random value (so staging-issued sessions/links never validate on prod):
SESSION_SECRET=CHANGE_ME_random_64_hex
# A SEPARATE Groq key so staging doesn't eat prod's daily token cap:
GROQ_API_KEY=CHANGE_ME_staging_groq_key

# --- Slack: a SEPARATE Slack app (or test workspace) whose redirect/Events/
#     Interactivity URLs point at api-staging.husn.io ---
SLACK_CLIENT_ID=CHANGE_ME
SLACK_CLIENT_SECRET=CHANGE_ME
SLACK_SIGNING_SECRET=CHANGE_ME

# --- Google / Microsoft / Jira: register the api-staging.husn.io/auth/*/callback
#     redirect URIs in those apps (or use separate staging apps). Reuse the
#     client ids/secrets from prod only if you add the staging callback URLs to
#     the same app; otherwise set separate staging ones here. ---
# GOOGLE_CLIENT_ID=...
# MS_CLIENT_ID=...
# JIRA_CLIENT_ID=...

# --- Auth wall: keep on (matches prod) or set 0 for easier manual testing ---
AUTH_REQUIRED=1

# --- Resend (bot/auth email). Reuse prod's verified sender, or a test key. ---
# RESEND_API_KEY=...
# RESEND_FROM=Husn <login@contact.husn.io>
