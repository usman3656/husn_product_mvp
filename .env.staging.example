# .env.staging.example — STAGING environment config (DEDICATED staging box).
#
# On the staging box, at ~/husn-staging/.env.staging :
#   1. cp .env.staging.example .env.staging
#   2. Fill in every CHANGE_ME with a STAGING-SPECIFIC value (never a prod secret).
#   3. chmod 600 .env.staging
#
# This file is self-contained — do NOT seed it from prod's live secrets. It
# lists every variable staging needs that compose doesn't inject. DATABASE_URL
# and REDIS_URL are built by docker-compose.staging.yml from POSTGRES_*/redis,
# so they are intentionally absent here. The boot validation requires
# SESSION_SECRET, PUBLIC_API_BASE_URL, PUBLIC_WEB_BASE_URL, CORS_ALLOWED_ORIGINS
# (all below) plus DATABASE_URL/REDIS_URL (from compose).

# --- Domains (drive Caddy routing, the web build, and OAuth redirect URIs) ---
DOMAIN_APP=staging.husn.io
DOMAIN_API=api-staging.husn.io
PUBLIC_WEB_BASE_URL=https://staging.husn.io
PUBLIC_API_BASE_URL=https://api-staging.husn.io
# REQUIRED — must list the staging web origin or the browser is blocked by CORS:
CORS_ALLOWED_ORIGINS=https://staging.husn.io

# --- TLS — the staging Caddy gets its own ACME account + certs on this box ---
ACME_EMAIL=you@example.com

# --- Cookies: host-only so a staging session can't be presented to prod
#     (and vice-versa). Do NOT set this to .husn.io. ---
COOKIE_DOMAIN=
ENVIRONMENT=staging

# --- Database: own name + a SEPARATE password (volume is already separate) ---
POSTGRES_DB=husn_staging
POSTGRES_USER=husn
POSTGRES_PASSWORD=CHANGE_ME_staging_db_password

# --- Secrets that MUST be separate from prod (a leaked staging secret must
#     never be valid against prod). Generate fresh: `openssl rand -hex 32` ---
SESSION_SECRET=CHANGE_ME_random_64_hex
# If prod uses a token-encryption key, give staging its OWN here too:
# TOKEN_ENCRYPTION_KEY=CHANGE_ME_separate_from_prod

# --- Separate Groq key so staging doesn't eat prod's daily token cap ---
GROQ_API_KEY=CHANGE_ME_staging_groq_key

# --- Slack: a SEPARATE Slack app whose OAuth Redirect URL, Events, and
#     Interactivity all point at https://api-staging.husn.io/... ---
SLACK_CLIENT_ID=CHANGE_ME
SLACK_CLIENT_SECRET=CHANGE_ME
SLACK_SIGNING_SECRET=CHANGE_ME

# --- Google / Microsoft / Jira: either separate staging OAuth apps, or add the
#     api-staging.husn.io/auth/<provider>/callback redirect URI to the existing
#     app. Set separate staging client creds here if you use separate apps. ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# MS_CLIENT_ID=...
# MS_CLIENT_SECRET=...
# JIRA_CLIENT_ID=...
# JIRA_CLIENT_SECRET=...

# --- Auth wall: keep on to mirror prod (set 0 only for easier manual testing) ---
AUTH_REQUIRED=1

# --- Resend (bot/auth email): a separate/test key so staging email + rate
#     limits don't touch prod. Reuse prod's verified sender only if intentional. ---
# RESEND_API_KEY=...
# RESEND_FROM=Husn <login@contact.husn.io>
